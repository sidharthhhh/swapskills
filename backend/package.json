{
  "name": "swapskills-backend",
  "version": "1.0.0",
  "description": "Skill Exchange Platform - Backend API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "migrate:up": "db-migrate up --migrations-dir ./database/migrations",
    "migrate:down": "db-migrate down --migrations-dir ./database/migrations",
    "migrate:create": "db-migrate create --migrations-dir ./database/migrations",
    "seed": "ts-node prisma/seed.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/multer": "^2.1.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "db-migrate": "^0.11.14",
    "db-migrate-mysql": "^3.0.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.11.0",
    "ioredis-mock": "^8.13.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "pg": "^8.21.0",
    "rate-limit-redis": "^5.0.0",
    "socket.io": "^4.8.3",
    "uuid": "^14.0.0",
    "winston": "^3.19.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/hpp": "^0.2.6",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.15.0",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^10.0.0",
    "nodemon": "^3.1.9",
    "prisma": "^7.8.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
