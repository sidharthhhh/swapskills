# Server
NODE_ENV=production
PORT=3000

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=swapskills_user
DB_PASS=CHANGE_ME_STRONG_PASSWORD
DB_NAME=swapskills
DB_CONNECTION_LIMIT=20

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# JWT (RS256) - Generate with: node -e "const crypto=require('crypto');const{privateKey,publicKey}=crypto.generateKeyPairSync('rsa',{modulusLength:2048,publicKeyEncoding:{type:'spki',format:'pem'},privateKeyEncoding:{type:'pkcs8',format:'pem'}});require('fs').writeFileSync('./keys/private.pem',privateKey);require('fs').writeFileSync('./keys/public.pem',publicKey);"
JWT_PRIVATE_KEY=./keys/private.pem
JWT_PUBLIC_KEY=./keys/public.pem
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# Admin JWT
ADMIN_JWT_SECRET=CHANGE_ME_MIN_32_CHARS_RANDOM_STRING

# CORS (comma-separated allowed origins for production)
CORS_ORIGINS=https://admin.swapskills.com,https://app.swapskills.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# Logging
LOG_LEVEL=info
